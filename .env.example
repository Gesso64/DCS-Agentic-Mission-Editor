# Copy this file to .env (or set these as environment variables).
# The bundled agent commands (design, edit, campaign, GUI) require ANTHROPIC_API_KEY.
# The MCP server and the deterministic CLI commands (build, validate, inspect, import)
# do NOT need an API key — they run entirely locally.

# Required for: design / edit / campaign CLI commands, and the chat GUI.
ANTHROPIC_API_KEY=sk-ant-...

# Optional: point at a LiteLLM or OpenRouter proxy to use any model through
# the Anthropic SDK wire format. When set, model aliases in --model / DEFAULT_MODELS
# are resolved by the proxy instead of Anthropic's servers.
# ANTHROPIC_BASE_URL=http://localhost:4000
